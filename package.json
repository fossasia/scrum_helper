{
  "name": "scrum-helper",
  "version": "2.1.4",
  "description": "This extension simplifies writing development reports by auto-filling content based on your Git activity.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fossasia/scrum_helper.git"
  },
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fix": "biome lint --write .",
    "check:write": "biome check --write .",
    "build": "node build.js",
    "tauri": "tauri"
  },
  "keywords": [
    "scrum",
    "google groups",
    "fossasia"
  ],
  "author": "FOSSASIA",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/fossasia/scrum_helper/issues"
  },
  "homepage": "https://github.com/fossasia/scrum_helper",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "autoprefixer": "^10.5.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.2"
  }
}
