{
  "name": "scrum-helper",
  "version": "2.1.4",
  "description": "This extension simplifies writing development reports by auto-filling content based on your Git activity.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fossasia/scrum_helper.git"
  },
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fix": "biome lint --write .",
    "check:write": "biome check --write ."
  },
  "keywords": [
    "scrum",
    "google groups",
    "fossasia"
  ],
  "author": "FOSSASIA",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/fossasia/scrum_helper/issues"
  },
  "homepage": "https://github.com/fossasia/scrum_helper",
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1"
  }
}
