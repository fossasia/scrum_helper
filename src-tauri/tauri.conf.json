{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "scrum-helper",
  "version": "0.1.0",
  "identifier": "org.fossasia.scrum-helper",
  "build": {
    "frontendDist": "../dist/tauri",
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Scrum Helper",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "popup.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
